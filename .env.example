# Embedding Provider
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
# Alternatives: 
#   paraphrase-multilingual-mpnet-base-v2 (lighter multilingual)
#   all-MiniLM-L6-v2 (dev/testing only)

# Vector Store
VECTOR_STORE=faiss
FAISS_INDEX_TYPE=flat  # flat | ivf

# Storage
DATA_DIR=./data
SQLITE_DB_PATH=./data/conversations.db

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# Retrieval
DEFAULT_TOP_K=5
MIN_SIMILARITY_THRESHOLD=0.5

# Cursor Transcripts
CURSOR_TRANSCRIPTS_DIR=~/.cursor/projects
AUTO_INGEST_ON_STARTUP=false

# Optional: Hugging Face token for private models (not needed for public models)
# HF_TOKEN=your_token_here
